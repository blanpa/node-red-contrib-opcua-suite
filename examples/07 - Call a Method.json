        "y": 40,
        "wires": []
    },
    {
        "id": "ex07-inject",
        "type": "inject",
        "z": "ex07-tab",
        "name": "Call with args",
        "props": [
            { "p": "payload", "vt": "json", "v": "[{\"dataType\":\"Double\",\"value\":3.14},{\"dataType\":\"String\",\"value\":\"hello\"}]" }
        ],
        "repeat": "",
        "crontab": "",
        "once": false,
        "onceDelay": 0.1,
        "topic": "",
        "payload": "",
        "payloadType": "date",
        "x": 150,
        "y": 120,
