        "id": "t3-assert",
        "type": "function",
        "z": "v13-t3",
        "name": "assert",
        "func": "const p = msg.payload || {};\nconst errs = [];\nif (Math.abs(p.V - 99.5) > 1e-9) errs.push(\"V=\" + p.V);\nif (p.Name !== \"json-t3\") errs.push(\"Name=\" + p.Name);\nif (msg.encoding !== \"json\") errs.push(\"encoding=\" + msg.encoding);\nif (msg.transport !== \"mqtt\") errs.push(\"transport=\" + msg.transport);\nif (msg.writerGroupId !== 33) errs.push(\"wgId(CR-02)=\" + msg.writerGroupId);\nif (typeof msg.publisherId !== \"number\") errs.push(\"pidType(HI-02)=\" + typeof msg.publisherId);\nif (msg.publisherId !== 305419896) errs.push(\"pid=\" + msg.publisherId);\nconst t = new Date(msg.timestamp).getTime();\nif (isNaN(t)) errs.push(\"ts not a date\");\nelse if (Math.abs(Date.now() - t) > 30000) errs.push(\"ts(HI-01) too far from now: \" + msg.timestamp);\nnode.warn(errs.length ? \"[VALIDATE] T3 mqtt-json: FAIL - \" + errs.join(\", \")\n                      : \"[VALIDATE] T3 mqtt-json: PASS\");\nreturn msg;",
