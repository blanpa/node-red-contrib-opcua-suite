        "func": "const p = msg.payload || {};\nconst errs = [];\nif (Math.abs(p.Temp - 42.25) > 1e-9) errs.push(\"Temp=\" + p.Temp);\nif (p.Tag !== \"mqtt-uadp-t2\") errs.push(\"Tag=\" + p.Tag);\nif (msg.encoding !== \"uadp\") errs.push(\"encoding=\" + msg.encoding);\nif (msg.transport !== \"mqtt\") errs.push(\"transport=\" + msg.transport);\nif (!msg.topic) errs.push(\"no topic\");\nnode.warn(errs.length ? \"[VALIDATE] T2 mqtt-uadp: FAIL - \" + errs.join(\", \")\n                      : \"[VALIDATE] T2 mqtt-uadp: PASS\");\nreturn msg;",
