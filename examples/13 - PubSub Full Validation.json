    {
        "id": "t1-assert",
        "type": "function",
        "z": "v13-t1",
        "name": "assert",
        "func": "const p = msg.payload || {};\nconst errs = [];\nif (Math.abs(p.D - 3.14159) > 1e-9) errs.push(\"D=\" + p.D);\nif (p.S !== \"hello-t1\") errs.push(\"S=\" + p.S);\nif (p.I !== -12345) errs.push(\"I=\" + p.I);\nif (p.B !== true) errs.push(\"B=\" + p.B);\nif (Math.abs(p.F - 1.5) > 1e-3) errs.push(\"F=\" + p.F);\nif (p.U !== 60000) errs.push(\"U=\" + p.U);\nif (msg.encoding !== \"uadp\") errs.push(\"encoding=\" + msg.encoding);\nif (msg.transport !== \"udp\") errs.push(\"transport=\" + msg.transport);\nif (msg.publisherId === undefined) errs.push(\"no publisherId\");\nif (msg.writerGroupId !== 1) errs.push(\"wgId=\" + msg.writerGroupId);\nif (msg.dataSetWriterId !== 1) errs.push(\"dswId=\" + msg.dataSetWriterId);\nif (msg.sequenceNumber === undefined) errs.push(\"no seq\");\nnode.warn(errs.length ? \"[VALIDATE] T1 udp-uadp-scalars: FAIL - \" + errs.join(\", \")\n                      : \"[VALIDATE] T1 udp-uadp-scalars: PASS\");\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 650,
        "y": 240,
        "wires": [
            [
                "t1-dbg"
